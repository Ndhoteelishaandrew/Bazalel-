// ── PROPHECY — REAL IMAGES via Pollinations.AI ────────────────
function ProphecyTab(){
  const [prompt,  setPrompt]  = useState("");
  const [style,   setStyle]   = useState("photorealistic");
  const [media,   setMedia]   = useState("image");
  const [loading, setLoading] = useState(false);
  const [gallery, setGallery] = useState([]);
  const [info,    setInfo]    = useState("");   // info/tip shown to user

  // Build the actual Pollinations URL
  const makeUrl = (p,s) => {
    const seed = Math.floor(Math.random()*999999);
    const full = encodeURIComponent(`${p}, ${s}, highly detailed, 4K`);
    return `https://image.pollinations.ai/prompt/${full}?width=768&height=512&seed=${seed}&nologo=true&model=flux`;
  };

  const generate = async () => {
    if(!prompt.trim()) return;
    setInfo("");

    // Music / Video — link out to free tools
    if(media !== "image"){
      setGallery(g=>[{
        type:media, prompt, ts:ts(),
        links: media==="music"
          ? [{label:"Suno.ai — free music AI",  url:"https://suno.com"},
             {label:"Udio.com — free music AI",  url:"https://udio.com"}]
          : [{label:"Runway ML — free video AI", url:"https://runwayml.com"},
             {label:"Kling AI — free video AI",  url:"https://klingai.com"}],
      },...g]);
      return;
    }

    setLoading(true);
    const url = makeUrl(prompt, style);

    // We show the image directly using the URL — no pre-load that can timeout
    // The <img> tag's own onLoad/onError handles it
    setGallery(g=>[{type:"image", url, prompt, style, ts:ts(), loaded:false},...g]);
    setPrompt("");
    setLoading(false);
    setInfo("Image is loading below — takes 5–20 seconds on first generation. Works instantly once deployed to Vercel.");
  };

  const markLoaded = (i) => {
    setGallery(g => g.map((item,idx) => idx===i ? {...item,loaded:true} : item));
    setInfo("");
  };
  const markError = () => {
    setInfo("The image generator (Pollinations.AI) is temporarily unavailable inside Claude's preview sandbox due to CORS restrictions. Your prompt is saved — once you deploy to Vercel it works perfectly. You can also open the link below to see the image now.");
  };

  return(
    <div>
      <div className="sec-title">Prophecy Studio</div>
      <div className="sec-sub">Real images — Pollinations.AI, free, no key needed</div>

      {/* Type selector */}
      <div className="card">
        <div className="card-hdr">Output Type</div>
        <div className="row">
          {[["image","🖼 Image"],["music","🎵 Music"],["video","🎬 Video"]].map(([id,lbl])=>(
            <button key={id} className={`btn btn-sm ${media===id?"btn-p":"btn-g"}`}
              onClick={()=>setMedia(id)}>{lbl}</button>
          ))}
        </div>
        {media==="image" && (
          <div style={{marginTop:12}}>
            <div style={{fontSize:11,color:"var(--dim)",marginBottom:6,fontWeight:600,textTransform:"uppercase",letterSpacing:".5px"}}>Style</div>
            <div className="tag-row">
              {STYLES.map(s=>(
                <button key={s} onClick={()=>setStyle(s)}
                  style={{padding:"4px 12px",borderRadius:20,
                    border:`1px solid ${style===s?"var(--accent)":"var(--div)"}`,
                    background:style===s?"rgba(82,136,193,.2)":"var(--surface2)",
                    color:style===s?"var(--accent2)":"var(--dim)",
                    fontSize:11,fontWeight:600,cursor:"pointer"}}>
                  {s}
                </button>
              ))}
            </div>
          </div>
        )}
      </div>

      {/* Tip */}
      {media==="image" && (
        <div className="tip">
          🆓 <strong style={{color:"var(--white)"}}>100% free.</strong> Uses Pollinations.AI — no account, no API key.
          Works fully on Vercel. Inside Claude preview, use the <strong style={{color:"var(--accent2)"}}>Open link</strong> button if image doesn't load.
        </div>
      )}

      {/* Input */}
      <div style={{display:"flex",gap:8,alignItems:"flex-end",marginBottom:10}}>
        <div style={{flex:1,background:"var(--surface2)",borderRadius:16,
          padding:"10px 14px",border:"1px solid var(--div)"}}>
          <textarea className="minput" rows={2} style={{width:"100%",resize:"none"}}
            placeholder={
              media==="image" ? "e.g. African sunset over Lake Victoria, golden hour, cinematic..."
              : media==="music" ? "e.g. Uplifting gospel choir, East African rhythm, sunrise energy..."
              : "e.g. Craftsman forging gold, slow motion, divine light..."
            }
            value={prompt} onChange={e=>setPrompt(e.target.value)}
            onKeyDown={e=>{ if(e.key==="Enter"&&!e.shiftKey){e.preventDefault();generate();} }}/>
        </div>
        <button className="sbtn" onClick={generate} disabled={loading||!prompt.trim()}>
          {loading?"⏳":"✨"}
        </button>
      </div>

      <div className="row" style={{marginBottom:12}}>
        <button className="btn btn-g btn-xs"
          onClick={()=>setPrompt(IMAGE_SAMPLES[Math.floor(Math.random()*IMAGE_SAMPLES.length)])}>
          ✦ Random prompt
        </button>
        {gallery.length>0 && (
          <button className="btn btn-g btn-xs" onClick={()=>setGallery([])}>Clear gallery</button>
        )}
      </div>

      {/* Info message */}
      {info && (
        <div className="tip" style={{marginBottom:10}}>
          ℹ️ {info}
        </div>
      )}

      {/* Empty state */}
      {gallery.length===0 && !loading && (
        <div className="empty">
          <span className="empty-ic">🎨</span>
          Your creations appear here.<br/>Type a prompt and tap ✨
          <div style={{fontSize:11,color:"var(--dim)",marginTop:8}}>
            Free via Pollinations.AI · No API key required
          </div>
        </div>
      )}

      {/* Gallery */}
      {gallery.map((item,i)=>(
        <div key={i}>
          {item.type==="image" && (
            <div className="img-card">
              {/* Show image directly — browser loads it natively */}
              <img
                src={item.url}
                alt={item.prompt}
                loading="lazy"
                onLoad={()=>markLoaded(i)}
                onError={markError}
                style={{
                  width:"100%",display:"block",
                  maxHeight:360,objectFit:"cover",
                  background:"var(--surface2)",
                  minHeight:item.loaded?0:200,
                }}
              />
              {!item.loaded && (
                <div style={{padding:"24px",textAlign:"center",
                  background:"var(--surface2)",marginTop:-200,
                  position:"relative",zIndex:1}}>
                  <span className="spin">⚙️</span>
                  <div style={{color:"var(--accent2)",fontSize:13,fontWeight:500}}>
                    Generating image...
                  </div>
                  <div style={{fontSize:11,color:"var(--dim)",marginTop:6}}>
                    5–20 seconds · Pollinations.AI
                  </div>
                </div>
              )}
              <div className="img-cap">{item.style} · {item.ts}</div>
              <div className="img-acts">
                <a href={item.url} target="_blank" rel="noreferrer"
                  className="btn btn-g btn-xs" style={{textDecoration:"none"}}>
                  🔗 Open link
                </a>
                <a href={item.url} download={`bezalel-${i}.jpg`} target="_blank" rel="noreferrer"
                  className="btn btn-p btn-xs" style={{textDecoration:"none"}}>
                  ⬇ Save
                </a>
              </div>
            </div>
          )}

          {(item.type==="music"||item.type==="video") && (
            <div className="card">
              <div className="card-hdr">{item.type==="music"?"🎵 Music":"🎬 Video"}</div>
              <div style={{fontSize:12,color:"var(--dim)",marginBottom:10,fontStyle:"italic"}}>
                "{item.prompt}"
              </div>
              {item.links.map((l,j)=>(
                <a key={j} href={l.url} target="_blank" rel="noreferrer"
                  style={{display:"flex",alignItems:"center",gap:8,
                    padding:"10px 14px",marginBottom:6,
                    background:"var(--surface2)",borderRadius:10,
                    color:"var(--accent2)",textDecoration:"none",
                    fontSize:13,fontWeight:500}}>
                  → {l.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  );
}

