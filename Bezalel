// helpers
const ts = () => new Date().toLocaleTimeString([],{hour:"2-digit",minute:"2-digit"});

// ── GENESIS ──────────────────────────────────────────────────
function GenesisTab({ apiKey }) {
  const [input, setInput] = useState("");
  const [msgs,  setMsgs]  = useState([]);
  const [busy,  setBusy]  = useState(false);
  const [pipe,  setPipe]  = useState(-1);
  const listRef = useRef(null);
  const inpRef  = useRef(null);

  const PIPE = [
    {n:"Prompter's Altar",   d:"Analysing intent"},
    {n:"Genesis Forge",      d:"AI generating code"},
    {n:"Live Preview",       d:"Rendering preview"},
    {n:"Jericho Deploy",     d:"GitHub → Vercel"},
    {n:"APK Compilation",    d:"On-device build"},
    {n:"Installation Rite",  d:"APK ready"},
  ];

  useEffect(()=>{ if(listRef.current) listRef.current.scrollTop=listRef.current.scrollHeight; },[msgs,busy]);

  const send = async () => {
    const t = input.trim(); if(!t) return;
    setInput(""); setBusy(true);
    setMsgs(m=>[...m,{r:"u",t,ts:ts()}]);
    inpRef.current?.focus();

    if(!apiKey){
      await new Promise(r=>setTimeout(r,700));
      setMsgs(m=>[...m,{r:"b",t:"⚠️ Add your Claude API key in Scribes → API Key Vault to activate the Genesis Engine. Stored locally, never shared.",ts:ts()}]);
      setBusy(false); return;
    }
    for(let i=0;i<2;i++){setPipe(i);await new Promise(r=>setTimeout(r,500));}
    try{
      const history = msgs.filter(m=>m.r==="u").slice(-4).map(m=>({role:"user",content:m.t}));
      const res = await fetch("https://api.anthropic.com/v1/messages",{
        method:"POST",
        headers:{"Content-Type":"application/json"},
        body:JSON.stringify({
          model:"claude-sonnet-4-20250514",
          max_tokens:1000,
          system:`You are Bezalel — the Spirit-filled AI App Forge, a world-class senior mobile developer.
When given an app request respond with:
1. A warm 1-sentence "Bezalel:" intro (master craftsman voice)
2. Complete production-ready React Native or Flutter code
3. A short deployment note
Make code genuinely functional with clean architecture and good comments.`,
          messages:[...history,{role:"user",content:t}],
        }),
      });
      const data = await res.json();
      const reply = data.content?.map(b=>b.text||"").join("")||"The Spirit is moving... try again.";
      for(let i=2;i<PIPE.length;i++){setPipe(i);await new Promise(r=>setTimeout(r,350));}
      setMsgs(m=>[...m,{r:"b",t:reply,ts:ts()}]);
    } catch(e){
      setMsgs(m=>[...m,{r:"b",t:`Error: ${e.message}`,ts:ts()}]);
    } finally { setBusy(false); setPipe(-1); }
  };

  return (
    <div style={{display:"flex",flexDirection:"column"}}>
      <div className="sec-title">Genesis Engine</div>
      <div className="sec-sub">Prompt → code → native APK, zero cost</div>

      {msgs.length===0 && (
        <div>
          <div className="tip">💡 Describe your app below. Press Enter or tap ➤ to forge.</div>
          <div className="tag-row" style={{marginBottom:10}}>
            {GENESIS_SAMPLES.slice(0,3).map(p=>(
              <button key={p} className="tag tg-dim"
                style={{whiteSpace:"normal",textAlign:"left",lineHeight:1.4,maxWidth:"100%"}}
                onClick={()=>{ setInput(p); inpRef.current?.focus(); }}>
                {p}
              </button>
            ))}
          </div>
        </div>
      )}

      <div className="chat-list" ref={listRef}>
        {msgs.map((m,i)=>(
          <div key={i} className={`brow ${m.r==="u"?"out":""}`}>
            {m.r==="b" && <div className="bav">✦</div>}
            <div className={`bub ${m.r==="u"?"out":"in"}`}>
              {m.t}
              <div className="btime">{m.ts}</div>
            </div>
          </div>
        ))}
        {busy && (
          <div className="brow">
            <div className="bav">✦</div>
            <div className="bub in">
              <div className="typing-bub">
                <div className="tdot"/><div className="tdot"/><div className="tdot"/>
              </div>
            </div>
          </div>
        )}
      </div>

      {busy && pipe>=0 && (
        <div className="card" style={{marginBottom:8}}>
          <div className="card-hdr">⚡ Jericho Pipeline</div>
          <div className="plist">
            {PIPE.map((s,i)=>(
              <div key={i} className="prow">
                <div className={`pnum ${i<pipe?"done":i===pipe?"run":""}`}>
                  {i<pipe?"✓":i+1}
                </div>
                <div><div className="pname">{s.n}</div><div className="pdesc">{s.d}</div></div>
              </div>
            ))}
          </div>
        </div>
      )}

      <div className="ibar">
        <div className="iwrap">
          <textarea ref={inpRef} className="minput" rows={1}
            placeholder="Describe your app..."
            value={input} onChange={e=>setInput(e.target.value)}
            onKeyDown={e=>{ if(e.key==="Enter"&&!e.shiftKey){e.preventDefault();send();} }} />
        </div>
        <button className="sbtn" onClick={send} disabled={busy||!input.trim()}>➤</button>
      </div>
    </div>
  );
}

// ── SANCTUM ───────────────────────────────────────────────────
function SanctumTab(){
  const [mod, setMod] = useState("");
  const [log, setLog] = useState("");
  const [busy,setBusy]= useState(false);

  const run = async()=>{
    if(!mod.trim()) return;
    setBusy(true); setLog("");
